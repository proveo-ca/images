#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

TARGETS=(
  "aider-node"
  "charles-proxy"
  "claude-standalone"
  "claude-chonky"
)

usage() {
  cat <<'EOF'
Usage:
  bin/probe list
  bin/probe help
  bin/probe build <target> [--no-cache]
  bin/probe test <target>
  bin/probe run <target> [-- <args...>]
  bin/probe debug <target> [-- <args...>]
  bin/probe deploy <target> [--tag <tag>]
  bin/probe uninstall

Targets:
  aider-node
  charles-proxy
  claude-standalone
  claude-chonky

Examples:
  bin/probe list
  bin/probe help
  bin/probe build aider-node
  bin/probe run aider-node
  bin/probe run claude-chonky -- --debug --mcp-debug
  bin/probe debug claude-standalone
  bin/probe deploy charles-proxy --tag latest
  bin/probe uninstall
EOF
}

print_error() {
  echo "❌ $*" >&2
}

print_info() {
  echo "ℹ️  $*"
}

print_success() {
  echo "✅ $*"
}

is_valid_target() {
  local target="$1"
  local item
  for item in "${TARGETS[@]}"; do
    if [[ "$item" == "$target" ]]; then
      return 0
    fi
  done
  return 1
}

require_target() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    print_error "Missing target."
    usage
    exit 1
  fi

  if ! is_valid_target "$target"; then
    print_error "Unknown target: $target"
    echo ""
    usage
    exit 1
  fi
}

list_targets() {
  echo "Available targets:"
  local target
  for target in "${TARGETS[@]}"; do
    echo "  - $target"
  done
}

is_ai_harness() {
  local target="$1"
  case "$target" in
    aider-node|claude-standalone|claude-chonky)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

image_name() {
  local target="$1"
  case "$target" in
    aider-node)
      echo "proveo/aider-node"
      ;;
    charles-proxy)
      echo "proveo/charles-proxy"
      ;;
    claude-standalone)
      echo "proveo/claude-standalone"
      ;;
    claude-chonky)
      echo "proveo/claude-chonky"
      ;;
    *)
      print_error "No image name mapping for target: $target"
      exit 1
      ;;
  esac
}

local_image_name() {
  local target="$1"
  case "$target" in
    aider-node)
      echo "proveo/aider-node"
      ;;
    charles-proxy)
      echo "proveo/charles-proxy"
      ;;
    claude-standalone)
      echo "claude-code-container"
      ;;
    claude-chonky)
      echo "claude-code-container-chonky"
      ;;
    *)
      print_error "No local image mapping for target: $target"
      exit 1
      ;;
  esac
}

is_pnpm_monorepo() {
  [[ -f "$REPO_ROOT/pnpm-workspace.yaml" ]]
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

parse_pnpm_workspace_globs() {
  local workspace_file="$REPO_ROOT/pnpm-workspace.yaml"
  [[ -f "$workspace_file" ]] || return 0

  awk '
    BEGIN { in_packages = 0 }
    /^[[:space:]]*packages:[[:space:]]*$/ { in_packages = 1; next }
    in_packages == 1 {
      if ($0 ~ /^[^[:space:]-]/) exit
      if ($0 ~ /^[[:space:]]*-[[:space:]]*/) {
        sub(/^[[:space:]]*-[[:space:]]*/, "", $0)
        gsub(/^["'\''"]|["'\''"]$/, "", $0)
        print $0
      }
    }
  ' "$workspace_file"
}

discover_workspaces() {
  local glob
  local candidate
  local -a globs=()

  while IFS= read -r glob; do
    glob="$(trim "$glob")"
    [[ -n "$glob" ]] || continue
    globs+=("$glob")
  done < <(parse_pnpm_workspace_globs)

  if [[ ${#globs[@]} -eq 0 ]]; then
    return 0
  fi

  (
    shopt -s nullglob globstar
    cd "$REPO_ROOT"

    for glob in "${globs[@]}"; do
      for candidate in $glob; do
        [[ -d "$candidate" ]] || continue
        [[ -f "$candidate/package.json" ]] || continue
        printf '%s\n' "$candidate"
      done
    done
  ) | awk '!seen[$0]++'
}

choose_scope() {
  local target="$1"
  local -a workspaces=()
  local selection
  local i

  if ! is_ai_harness "$target"; then
    echo "$PWD"
    return 0
  fi

  if ! is_pnpm_monorepo; then
    echo "$PWD"
    return 0
  fi

  while IFS= read -r workspace; do
    [[ -n "$workspace" ]] || continue
    workspaces+=("$workspace")
  done < <(discover_workspaces)

  if [[ ${#workspaces[@]} -eq 0 ]]; then
    echo "$PWD"
    return 0
  fi

  local default_scope="$PWD"
  local default_label
  if [[ "$PWD" == "$REPO_ROOT" ]]; then
    default_label="repo root"
  elif [[ "$PWD" == "$REPO_ROOT/"* ]]; then
    default_label="${PWD#$REPO_ROOT/}"
  else
    default_label="$PWD"
  fi

  echo "Detected pnpm monorepo: $REPO_ROOT" >&2
  echo "Select scope for $target:" >&2
  echo "  0) current directory ($default_label)" >&2
  echo "  1) repo root" >&2

  for i in "${!workspaces[@]}"; do
    printf '  %d) %s\n' "$((i + 2))" "${workspaces[$i]}" >&2
  done

  while true; do
    read -r -p "Choice [0]: " selection
    selection="${selection:-0}"

    if [[ "$selection" =~ ^[0-9]+$ ]]; then
      if [[ "$selection" -eq 0 ]]; then
        echo "$default_scope"
        return 0
      fi

      if [[ "$selection" -eq 1 ]]; then
        echo "$REPO_ROOT"
        return 0
      fi

      if [[ "$selection" -ge 2 && "$selection" -lt $(( ${#workspaces[@]} + 2 )) ]]; then
        echo "$REPO_ROOT/${workspaces[$((selection - 2))]}"
        return 0
      fi
    fi

    print_error "Invalid selection."
  done
}

container_name_for_scope() {
  local scope_dir="$1"
  local repo_name
  local scope_name

  repo_name="$(basename "$REPO_ROOT")"

  if [[ "$scope_dir" == "$REPO_ROOT" ]]; then
    echo "$repo_name"
    return 0
  fi

  scope_name="${scope_dir#$REPO_ROOT/}"
  scope_name="${scope_name//\//-}"
  echo "${repo_name}-${scope_name}"
}

ensure_image_available() {
  local image="$1"
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    print_error "Docker image not found locally: $image"
    print_info "Build it first with: bin/proveo build ${2:-<target>}"
    exit 1
  fi
}

default_claude_data_dir() {
  local scope_dir="$1"
  local candidate="$scope_dir/workspace/data"
  if [[ -d "$candidate" ]]; then
    echo "$candidate"
  fi
}

default_claude_output_dir() {
  local scope_dir="$1"
  echo "$scope_dir/reports"
}

build_target() {
  local target="$1"
  local no_cache="${2:-}"

  case "$target" in
    aider-node)
      print_info "Building $target..."
      docker build ${no_cache:+$no_cache} -t "$(image_name "$target")" "$REPO_ROOT/aider-node"
      print_success "Built $(image_name "$target")"
      ;;
    charles-proxy)
      print_info "Building $target..."
      docker build ${no_cache:+$no_cache} -t "$(image_name "$target")" "$REPO_ROOT/charles-proxy"
      print_success "Built $(image_name "$target")"
      ;;
    claude-standalone)
      print_info "Building $target..."
      (
        cd "$REPO_ROOT/claude-code/standalone"
        if [[ -n "$no_cache" ]]; then
          ./build.sh --no-cache
        else
          ./build.sh
        fi
      )
      docker tag "$(local_image_name "$target")" "$(image_name "$target"):latest"
      print_success "Built $(local_image_name "$target") and tagged $(image_name "$target"):latest"
      ;;
    claude-chonky)
      print_info "Building $target..."
      (
        cd "$REPO_ROOT/claude-code/chonky"
        if [[ -n "$no_cache" ]]; then
          ./build.chonky.sh --no-cache
        else
          ./build.chonky.sh
        fi
      )
      docker tag "$(local_image_name "$target")" "$(image_name "$target"):latest"
      print_success "Built $(local_image_name "$target") and tagged $(image_name "$target"):latest"
      ;;
    *)
      print_error "Unsupported build target: $target"
      exit 1
      ;;
  esac
}

test_target() {
  local target="$1"

  case "$target" in
    claude-standalone|claude-chonky)
      print_info "Running Claude test suite for $target..."
      (
        cd "$REPO_ROOT/claude-code/tests"
        ./run_tests.sh
      )
      ;;
    aider-node)
      print_info "Running smoke tests for aider-node..."
      ensure_image_available "$(image_name "$target")" "$target"
      docker run --rm "$(image_name "$target")" bash -lc 'node --version && npm -v && pnpm -v && aider --version'
      ;;
    charles-proxy)
      print_info "Running smoke tests for charles-proxy..."
      ensure_image_available "$(image_name "$target")" "$target"
      docker run --rm --entrypoint /bin/bash "$(image_name "$target")" -lc 'charles -help >/dev/null'
      ;;
    *)
      print_error "Unsupported test target: $target"
      exit 1
      ;;
  esac

  print_success "Tests passed for $target"
}

run_aider_node() {
  local scope_dir="$1"
  shift
  local -a extra_args=("$@")

  local image
  local repo_name
  image="$(image_name "aider-node")"
  ensure_image_available "$image" "aider-node"

  repo_name="$(container_name_for_scope "$scope_dir")"

  if [[ "$scope_dir" == "$REPO_ROOT" ]]; then
    print_info "Running aider-node at repo root"
    docker run -it --rm \
      --name "$repo_name" \
      -v "$REPO_ROOT:/app" \
      -w /app \
      "$image" \
      "${extra_args[@]}"
    return 0
  fi

  if [[ "$scope_dir" != "$REPO_ROOT/"* ]]; then
    print_info "Running aider-node in current directory"
    docker run -it --rm \
      --name "$repo_name" \
      -v "$scope_dir:/app" \
      -w /app \
      "$image" \
      "${extra_args[@]}"
    return 0
  fi

  local relative_scope
  relative_scope="${scope_dir#$REPO_ROOT/}"

  print_info "Running aider-node with monorepo workspace: $relative_scope"

  local -a docker_args=(
    run -it --rm
    --name "$repo_name"
    -v "$scope_dir:/app/$relative_scope"
    -v "$REPO_ROOT/.git:/app/.git"
    -w /app
  )

  if [[ -f "$scope_dir/.aiderignore" ]]; then
    docker_args+=(-v "$scope_dir/.aiderignore:/app/.aiderignore")
  fi

  docker_args+=("$image")
  docker_args+=("${extra_args[@]}")

  docker "${docker_args[@]}"
}

debug_aider_node() {
  local scope_dir="$1"
  shift
  local -a extra_args=("$@")

  local image
  local repo_name
  image="$(image_name "aider-node")"
  ensure_image_available "$image" "aider-node"

  repo_name="$(container_name_for_scope "$scope_dir")"

  if [[ "$scope_dir" == "$REPO_ROOT" ]]; then
    docker run -it --rm \
      --name "${repo_name}-debug" \
      --entrypoint /bin/bash \
      -v "$REPO_ROOT:/app" \
      -w /app \
      "$image" \
      "${extra_args[@]}"
    return 0
  fi

  if [[ "$scope_dir" != "$REPO_ROOT/"* ]]; then
    docker run -it --rm \
      --name "${repo_name}-debug" \
      --entrypoint /bin/bash \
      -v "$scope_dir:/app" \
      -w /app \
      "$image" \
      "${extra_args[@]}"
    return 0
  fi

  local relative_scope
  relative_scope="${scope_dir#$REPO_ROOT/}"

  local -a docker_args=(
    run -it --rm
    --name "${repo_name}-debug"
    --entrypoint /bin/bash
    -v "$scope_dir:/app/$relative_scope"
    -v "$REPO_ROOT/.git:/app/.git"
    -w /app
  )

  if [[ -f "$scope_dir/.aiderignore" ]]; then
    docker_args+=(-v "$scope_dir/.aiderignore:/app/.aiderignore")
  fi

  docker_args+=("$image")
  docker_args+=("${extra_args[@]}")

  docker "${docker_args[@]}"
}

run_claude_wrapper() {
  local target="$1"
  local scope_dir="$2"
  shift 2
  local -a extra_args=("$@")

  local output_dir
  local data_dir
  local -a wrapper_args=()

  output_dir="$(default_claude_output_dir "$scope_dir")"
  data_dir="$(default_claude_data_dir "$scope_dir" || true)"

  mkdir -p "$output_dir"

  wrapper_args+=(--input-dir "$scope_dir" --output-dir "$output_dir")
  if [[ -n "$data_dir" ]]; then
    wrapper_args+=(--data-dir "$data_dir")
  fi
  wrapper_args+=("${extra_args[@]}")

  case "$target" in
    claude-standalone)
      ensure_image_available "$(local_image_name "$target")" "$target"
      "$REPO_ROOT/claude-code/standalone/run_claude.sh" "${wrapper_args[@]}"
      ;;
    claude-chonky)
      ensure_image_available "$(local_image_name "$target")" "$target"
      "$REPO_ROOT/claude-code/chonky/run_claude.chonky.sh" "${wrapper_args[@]}"
      ;;
    *)
      print_error "Unsupported Claude run target: $target"
      exit 1
      ;;
  esac
}

debug_claude_wrapper() {
  local target="$1"
  local scope_dir="$2"
  shift 2
  local -a extra_args=("$@")

  local output_dir
  local data_dir
  local -a wrapper_args=()

  output_dir="$(default_claude_output_dir "$scope_dir")"
  data_dir="$(default_claude_data_dir "$scope_dir" || true)"

  mkdir -p "$output_dir"

  wrapper_args+=(--input-dir "$scope_dir" --output-dir "$output_dir")
  if [[ -n "$data_dir" ]]; then
    wrapper_args+=(--data-dir "$data_dir")
  fi
  wrapper_args+=("${extra_args[@]}")

  case "$target" in
    claude-standalone)
      ensure_image_available "$(local_image_name "$target")" "$target"
      "$REPO_ROOT/claude-code/standalone/debug-shell.sh" "${wrapper_args[@]}"
      ;;
    claude-chonky)
      ensure_image_available "$(local_image_name "$target")" "$target"
      "$REPO_ROOT/claude-code/chonky/debug-shell.chonky.sh" "${wrapper_args[@]}"
      ;;
    *)
      print_error "Unsupported Claude debug target: $target"
      exit 1
      ;;
  esac
}

run_charles_proxy() {
  local image
  image="$(image_name "charles-proxy")"
  ensure_image_available "$image" "charles-proxy"

  local sessions_dir="$PWD/sessions"
  local config_dir="$PWD/config"

  mkdir -p "$sessions_dir" "$config_dir"

  print_info "Running charles-proxy on port 8888"
  docker run -it --rm \
    -p 8888:8888 \
    -v "$sessions_dir:/sessions" \
    -v "$config_dir:/config" \
    "$image"
}

debug_charles_proxy() {
  local image
  image="$(image_name "charles-proxy")"
  ensure_image_available "$image" "charles-proxy"

  local sessions_dir="$PWD/sessions"
  local config_dir="$PWD/config"

  mkdir -p "$sessions_dir" "$config_dir"

  print_info "Starting debug shell for charles-proxy"
  docker run -it --rm \
    --entrypoint /bin/bash \
    -p 8888:8888 \
    -v "$sessions_dir:/sessions" \
    -v "$config_dir:/config" \
    "$image"
}

run_target() {
  local target="$1"
  shift
  local -a extra_args=("$@")
  local scope_dir

  case "$target" in
    aider-node)
      scope_dir="$(choose_scope "$target")"
      run_aider_node "$scope_dir" "${extra_args[@]}"
      ;;
    claude-standalone|claude-chonky)
      scope_dir="$(choose_scope "$target")"
      run_claude_wrapper "$target" "$scope_dir" "${extra_args[@]}"
      ;;
    charles-proxy)
      run_charles_proxy
      ;;
    *)
      print_error "Unsupported run target: $target"
      exit 1
      ;;
  esac
}

debug_target() {
  local target="$1"
  shift
  local -a extra_args=("$@")
  local scope_dir

  case "$target" in
    aider-node)
      scope_dir="$(choose_scope "$target")"
      debug_aider_node "$scope_dir" "${extra_args[@]}"
      ;;
    claude-standalone|claude-chonky)
      scope_dir="$(choose_scope "$target")"
      debug_claude_wrapper "$target" "$scope_dir" "${extra_args[@]}"
      ;;
    charles-proxy)
      debug_charles_proxy
      ;;
    *)
      print_error "Unsupported debug target: $target"
      exit 1
      ;;
  esac
}

deploy_target() {
  local target="$1"
  local tag="${2:-latest}"

  local publish_image
  local local_image
  publish_image="$(image_name "$target"):$tag"
  local_image="$(local_image_name "$target")"

  ensure_image_available "$local_image" "$target"

  print_info "Tagging $local_image as $publish_image"
  docker tag "$local_image" "$publish_image"

  print_info "Pushing $publish_image"
  docker push "$publish_image"

  print_success "Deployed $publish_image"
}

show_help_command() {
  "$SCRIPT_DIR/help.sh"
}

run_uninstall() {
  "$REPO_ROOT/uninstall.sh"
}

parse_args() {
  local command="${1:-}"
  shift || true

  case "$command" in
    list)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'list' does not accept arguments."
        exit 1
      fi
      list_targets
      ;;
    help)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'help' does not accept arguments."
        exit 1
      fi
      show_help_command
      ;;
    build)
      local target="${1:-}"
      local no_cache=""
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --no-cache)
            no_cache="--no-cache"
            shift
            ;;
          *)
            print_error "Unknown build option: $1"
            exit 1
            ;;
        esac
      done

      build_target "$target" "$no_cache"
      ;;
    test)
      local target="${1:-}"
      require_target "$target"
      shift || true

      if [[ $# -ne 0 ]]; then
        print_error "Command 'test' does not accept extra arguments."
        exit 1
      fi

      test_target "$target"
      ;;
    run)
      local target="${1:-}"
      require_target "$target"
      shift || true

      if [[ "${1:-}" == "--" ]]; then
        shift
      fi

      run_target "$target" "$@"
      ;;
    debug)
      local target="${1:-}"
      require_target "$target"
      shift || true

      if [[ "${1:-}" == "--" ]]; then
        shift
      fi

      debug_target "$target" "$@"
      ;;
    deploy)
      local target="${1:-}"
      local tag="latest"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown deploy option: $1"
            exit 1
            ;;
        esac
      done

      deploy_target "$target" "$tag"
      ;;
    uninstall)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'uninstall' does not accept arguments."
        exit 1
      fi
      run_uninstall
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      print_error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

parse_args "$@"
