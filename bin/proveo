#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONSUMER_UNINSTALL_SCRIPT="$REPO_ROOT/apps/cli/public/images/uninstall.sh"

TARGETS=(
  "aider-node"
  "charles-proxy"
  "opencode"
  "claudecode"
  "claudecode-solo"
)

usage() {
  cat <<'EOF'
Usage:
  bin/proveo list
  bin/proveo help
  bin/proveo build <target> --tag <tag> [--no-cache]
  bin/proveo test <target>
  bin/proveo run <target> --tag <tag> [-- <args...>]
  bin/proveo debug <target> --tag <tag> [-- <args...>]
  bin/proveo deploy <target> --tag <tag>
  bin/proveo uninstall

Targets:
  aider-node
  charles-proxy
  opencode
  claudecode
  claudecode-solo

Examples:
  bin/proveo list
  bin/proveo help
  bin/proveo build aider-node --tag latest
  bin/proveo build claudecode --tag latest
  bin/proveo build opencode --tag latest
  bin/proveo run aider-node --tag latest
  bin/proveo run claudecode --tag latest -- --debug --mcp-debug
  bin/proveo debug claudecode-solo --tag latest
  bin/proveo deploy charles-proxy --tag latest
  bin/proveo uninstall
EOF
}

print_error() {
  echo "❌ $*" >&2
}

print_info() {
  echo "ℹ️  $*"
}

print_success() {
  echo "✅ $*"
}

is_valid_target() {
  local target="$1"
  local item
  for item in "${TARGETS[@]}"; do
    if [[ "$item" == "$target" ]]; then
      return 0
    fi
  done
  return 1
}

require_target() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    print_error "Missing target."
    usage
    exit 1
  fi

  if ! is_valid_target "$target"; then
    print_error "Unknown target: $target"
    echo ""
    usage
    exit 1
  fi
}

require_tag() {
  local tag="${1:-}"
  local command_name="${2:-command}"
  if [[ -z "$tag" ]]; then
    print_error "Command '$command_name' requires --tag <tag>."
    exit 1
  fi
}

list_targets() {
  echo "Available targets:"
  local target
  for target in "${TARGETS[@]}"; do
    echo "  - $target"
  done
}

is_ai_harness() {
  local target="$1"
  case "$target" in
    aider-node|claudecode|claudecode-solo|opencode)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

image_name() {
  local target="$1"
  case "$target" in
    aider-node)
      echo "proveo/aider-node"
      ;;
    charles-proxy)
      echo "proveo/charles-proxy"
      ;;
    opencode)
      echo "proveo/opencode"
      ;;
    claudecode)
      echo "proveo/claudecode"
      ;;
    claudecode-solo)
      echo "proveo/claudecode-solo"
      ;;
    *)
      print_error "No image name mapping for target: $target"
      exit 1
      ;;
  esac
}

target_dir() {
  local target="$1"
  case "$target" in
    aider-node)
      echo "$REPO_ROOT/defs/aider-node"
      ;;
    charles-proxy)
      echo "$REPO_ROOT/defs/charles-proxy"
      ;;
    opencode)
      echo "$REPO_ROOT/defs/opencode"
      ;;
    claudecode|claudecode-solo)
      echo "$REPO_ROOT/defs/claudecode"
      ;;
    *)
      print_error "No directory mapping for target: $target"
      exit 1
      ;;
  esac
}

find_script_in_dir() {
  local dir="$1"
  shift
  local script_name
  for script_name in "$@"; do
    if [[ -f "$dir/$script_name" ]]; then
      echo "$dir/$script_name"
      return 0
    fi
  done
  return 1
}

is_pnpm_monorepo() {
  [[ -f "$REPO_ROOT/pnpm-workspace.yaml" ]]
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

parse_pnpm_workspace_globs() {
  local workspace_file="$REPO_ROOT/pnpm-workspace.yaml"
  [[ -f "$workspace_file" ]] || return 0

  awk '
    BEGIN { in_packages = 0 }
    /^[[:space:]]*packages:[[:space:]]*$/ { in_packages = 1; next }
    in_packages == 1 {
      if ($0 ~ /^[^[:space:]-]/) exit
      if ($0 ~ /^[[:space:]]*-[[:space:]]*/) {
        sub(/^[[:space:]]*-[[:space:]]*/, "", $0)
        gsub(/^["'\''"]|["'\''"]$/, "", $0)
        print $0
      }
    }
  ' "$workspace_file"
}

discover_workspaces() {
  local glob
  local candidate
  local -a globs=()

  while IFS= read -r glob; do
    glob="$(trim "$glob")"
    [[ -n "$glob" ]] || continue
    globs+=("$glob")
  done < <(parse_pnpm_workspace_globs)

  if [[ ${#globs[@]} -eq 0 ]]; then
    return 0
  fi

  (
    shopt -s nullglob globstar
    cd "$REPO_ROOT"

    for glob in "${globs[@]}"; do
      for candidate in $glob; do
        [[ -d "$candidate" ]] || continue
        [[ -f "$candidate/package.json" ]] || continue
        printf '%s\n' "$candidate"
      done
    done
  ) | awk '!seen[$0]++'
}

choose_scope() {
  local target="$1"
  local -a workspaces=()
  local selection
  local i

  if ! is_ai_harness "$target"; then
    echo "$PWD"
    return 0
  fi

  if ! is_pnpm_monorepo; then
    echo "$PWD"
    return 0
  fi

  while IFS= read -r workspace; do
    [[ -n "$workspace" ]] || continue
    workspaces+=("$workspace")
  done < <(discover_workspaces)

  if [[ ${#workspaces[@]} -eq 0 ]]; then
    echo "$PWD"
    return 0
  fi

  local default_scope="$PWD"
  local default_label
  if [[ "$PWD" == "$REPO_ROOT" ]]; then
    default_label="repo root"
  elif [[ "$PWD" == "$REPO_ROOT/"* ]]; then
    default_label="${PWD#$REPO_ROOT/}"
  else
    default_label="$PWD"
  fi

  echo "Detected pnpm monorepo: $REPO_ROOT" >&2
  echo "Select scope for $target:" >&2
  echo "  0) current directory ($default_label)" >&2
  echo "  1) repo root" >&2

  for i in "${!workspaces[@]}"; do
    printf '  %d) %s\n' "$((i + 2))" "${workspaces[$i]}" >&2
  done

  while true; do
    read -r -p "Choice [0]: " selection
    selection="${selection:-0}"

    if [[ "$selection" =~ ^[0-9]+$ ]]; then
      if [[ "$selection" -eq 0 ]]; then
        echo "$default_scope"
        return 0
      fi

      if [[ "$selection" -eq 1 ]]; then
        echo "$REPO_ROOT"
        return 0
      fi

      if [[ "$selection" -ge 2 && "$selection" -lt $(( ${#workspaces[@]} + 2 )) ]]; then
        echo "$REPO_ROOT/${workspaces[$((selection - 2))]}"
        return 0
      fi
    fi

    print_error "Invalid selection."
  done
}

container_name_for_scope() {
  local scope_dir="$1"
  local repo_name
  local scope_name

  repo_name="$(basename "$REPO_ROOT")"

  if [[ "$scope_dir" == "$REPO_ROOT" ]]; then
    echo "$repo_name"
    return 0
  fi

  scope_name="${scope_dir#$REPO_ROOT/}"
  scope_name="${scope_name//\//-}"
  echo "${repo_name}-${scope_name}"
}

ensure_image_available() {
  local image="$1"
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    print_error "Docker image not found locally: $image"
    print_info "Build it first with: bin/proveo build ${2:-<target>} --tag <tag>"
    exit 1
  fi
}

default_claude_data_dir() {
  local scope_dir="$1"
  local candidate="$scope_dir/workspace/data"
  if [[ -d "$candidate" ]]; then
    echo "$candidate"
  fi
}

default_claude_output_dir() {
  local scope_dir="$1"
  echo "$scope_dir/reports"
}

build_target() {
  local target="$1"
  local tag="$2"
  local no_cache="${3:-}"
  local dir
  dir="$(target_dir "$target")"

  local build_script=""
  build_script="$(find_script_in_dir "$dir" build.sh build.bash 2>/dev/null || true)"

  if [[ -n "$build_script" ]]; then
    print_info "Building $target with tag $tag via $(basename "$build_script")..."
    (
      cd "$dir"
      case "$target" in
        claudecode)
          if [[ -n "$no_cache" ]]; then
            "$build_script" --variant mcp --tag "$tag" --no-cache
          else
            "$build_script" --variant mcp --tag "$tag"
          fi
          ;;
        claudecode-solo)
          if [[ -n "$no_cache" ]]; then
            "$build_script" --variant solo --tag "$tag" --no-cache
          else
            "$build_script" --variant solo --tag "$tag"
          fi
          ;;
        *)
          if [[ -n "$no_cache" ]]; then
            "$build_script" --no-cache
          else
            "$build_script"
          fi
          ;;
      esac
    )

    if docker image inspect "$(image_name "$target")" >/dev/null 2>&1; then
      docker tag "$(image_name "$target")" "$(image_name "$target"):$tag"
    fi

    ensure_image_available "$(image_name "$target"):$tag" "$target"
    print_success "Built $(image_name "$target"):$tag"
    return 0
  fi

  print_info "Building $target with tag $tag via docker build fallback..."
  docker build ${no_cache:+$no_cache} -t "$(image_name "$target"):$tag" -f "$dir/Dockerfile" "$dir"
  print_success "Built $(image_name "$target"):$tag"
}

test_target() {
  local target="$1"
  local dir
  dir="$(target_dir "$target")"

  local test_script=""
  test_script="$(find_script_in_dir "$dir" test.sh test.bash 2>/dev/null || true)"

  if [[ -n "$test_script" ]]; then
    print_info "Running tests for $target via $(basename "$test_script")..."
    (
      cd "$dir"
      "$test_script"
    )
    print_success "Tests passed for $target"
    return 0
  fi

  case "$target" in
    claudecode|claudecode-solo)
      local claude_tests="$REPO_ROOT/defs/claudecode/tests/run_tests.sh"
      if [[ -f "$claude_tests" ]]; then
        print_info "Running tests for $target via defs/claudecode/tests/run_tests.sh..."
        "$claude_tests"
        print_success "Tests passed for $target"
        return 0
      fi
      ;;
  esac

  print_error "No test script found for $target and no fallback is defined."
  exit 1
}

run_aider_node() {
  local scope_dir="$1"
  local tag="$2"
  shift 2
  local -a extra_args=("$@")

  local image
  local dir
  local run_script
  image="$(image_name "aider-node"):$tag"
  dir="$(target_dir "aider-node")"
  run_script="$(find_script_in_dir "$dir" run.sh 2>/dev/null || true)"

  ensure_image_available "$image" "aider-node"

  if [[ -n "$run_script" ]]; then
    print_info "Running aider-node via defs/aider-node/run.sh"
    "$run_script" --image "$image" --input-dir "$scope_dir" --repo-root "$REPO_ROOT" -- "${extra_args[@]}"
    return 0
  fi

  print_error "No run.sh found for aider-node at $dir"
  exit 1
}

debug_aider_node() {
  local scope_dir="$1"
  local tag="$2"
  shift 2
  local -a extra_args=("$@")

  local image
  local dir
  local debug_script
  image="$(image_name "aider-node"):$tag"
  dir="$(target_dir "aider-node")"
  debug_script="$(find_script_in_dir "$dir" debug.sh 2>/dev/null || true)"

  ensure_image_available "$image" "aider-node"

  if [[ -n "$debug_script" ]]; then
    print_info "Debugging aider-node via defs/aider-node/debug.sh"
    "$debug_script" --image "$image" --input-dir "$scope_dir" --repo-root "$REPO_ROOT" -- "${extra_args[@]}"
    return 0
  fi

  print_error "No debug.sh found for aider-node at $dir"
  exit 1
}

run_claude_wrapper() {
  local target="$1"
  local scope_dir="$2"
  local tag="$3"
  shift 3
  local -a extra_args=("$@")

  local dir
  local output_dir
  local data_dir
  dir="$(target_dir "$target")"
  output_dir="$(default_claude_output_dir "$scope_dir")"
  data_dir="$(default_claude_data_dir "$scope_dir" || true)"

  mkdir -p "$output_dir"

  local run_script=""
  run_script="$(find_script_in_dir "$dir" run.sh run_claude.sh 2>/dev/null || true)"

  if [[ -n "$run_script" ]]; then
    print_info "Running $target via $(basename "$run_script")..."
    (
      cd "$dir"
      if [[ -n "$data_dir" ]]; then
        PROVEO_CLAUDE_IMAGE="$(image_name "$target"):$tag" \
        "$run_script" --input-dir "$scope_dir" --output-dir "$output_dir" --data-dir "$data_dir" "${extra_args[@]}"
      else
        PROVEO_CLAUDE_IMAGE="$(image_name "$target"):$tag" \
        "$run_script" --input-dir "$scope_dir" --output-dir "$output_dir" "${extra_args[@]}"
      fi
    )
    return 0
  fi

  local image
  image="$(image_name "$target"):$tag"
  ensure_image_available "$image" "$target"

  local -a docker_args=(
    run -it --rm
    --cap-drop=ALL
    --security-opt=no-new-privileges:true
    --tmpfs /tmp:noexec,nosuid,size=100m
    --tmpfs /workspace/temp:noexec,nosuid,size=2g
    --pids-limit=100
    --network=bridge
    --add-host=host.docker.internal:127.0.0.1
    -v "$scope_dir:/workspace/input:ro"
    -v "$output_dir:/workspace/output:rw"
    -e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}"
  )

  if [[ -n "$data_dir" ]]; then
    docker_args+=(-v "$data_dir:/workspace/data:ro")
  fi

  docker_args+=("$image")
  docker_args+=("${extra_args[@]}")

  docker "${docker_args[@]}"
}

debug_claude_wrapper() {
  local target="$1"
  local scope_dir="$2"
  local tag="$3"
  shift 3
  local -a extra_args=("$@")

  local dir
  local output_dir
  local data_dir
  dir="$(target_dir "$target")"
  output_dir="$(default_claude_output_dir "$scope_dir")"
  data_dir="$(default_claude_data_dir "$scope_dir" || true)"

  mkdir -p "$output_dir"

  local debug_script=""
  debug_script="$(find_script_in_dir "$dir" debug.sh debug-shell.sh 2>/dev/null || true)"

  if [[ -n "$debug_script" ]]; then
    print_info "Debugging $target via $(basename "$debug_script")..."
    (
      cd "$dir"
      if [[ -n "$data_dir" ]]; then
        PROVEO_CLAUDE_IMAGE="$(image_name "$target"):$tag" \
        "$debug_script" --input-dir "$scope_dir" --output-dir "$output_dir" --data-dir "$data_dir" "${extra_args[@]}"
      else
        PROVEO_CLAUDE_IMAGE="$(image_name "$target"):$tag" \
        "$debug_script" --input-dir "$scope_dir" --output-dir "$output_dir" "${extra_args[@]}"
      fi
    )
    return 0
  fi

  local image
  image="$(image_name "$target"):$tag"
  ensure_image_available "$image" "$target"

  local -a docker_args=(
    run -it --rm
    --entrypoint bash
    --cap-drop=ALL
    --security-opt=no-new-privileges:true
    --tmpfs /tmp:noexec,nosuid,size=100m
    --tmpfs /workspace/temp:noexec,nosuid,size=2g
    --pids-limit=100
    --network=bridge
    --add-host=host.docker.internal:127.0.0.1
    -v "$scope_dir:/workspace/input:ro"
    -v "$output_dir:/workspace/output:rw"
    -e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}"
  )

  if [[ -n "$data_dir" ]]; then
    docker_args+=(-v "$data_dir:/workspace/data:ro")
  fi

  docker_args+=("$image")
  docker_args+=("${extra_args[@]}")

  docker "${docker_args[@]}"
}

run_charles_proxy() {
  local tag="$1"
  shift

  local image
  local dir
  local run_script
  image="$(image_name "charles-proxy"):$tag"
  dir="$(target_dir "charles-proxy")"
  run_script="$(find_script_in_dir "$dir" run.sh 2>/dev/null || true)"

  ensure_image_available "$image" "charles-proxy"

  if [[ -n "$run_script" ]]; then
    print_info "Running charles-proxy via defs/charles-proxy/run.sh"
    "$run_script" --image "$image" "$@"
    return 0
  fi

  print_error "No run.sh found for charles-proxy at $dir"
  exit 1
}

debug_charles_proxy() {
  local tag="$1"
  shift

  local image
  local dir
  local debug_script
  image="$(image_name "charles-proxy"):$tag"
  dir="$(target_dir "charles-proxy")"
  debug_script="$(find_script_in_dir "$dir" debug.sh 2>/dev/null || true)"

  ensure_image_available "$image" "charles-proxy"

  if [[ -n "$debug_script" ]]; then
    print_info "Debugging charles-proxy via defs/charles-proxy/debug.sh"
    "$debug_script" --image "$image" "$@"
    return 0
  fi

  print_error "No debug.sh found for charles-proxy at $dir"
  exit 1
}

run_target() {
  local target="$1"
  local tag="$2"
  shift 2
  local -a extra_args=("$@")
  local scope_dir

  case "$target" in
    aider-node)
      scope_dir="$(choose_scope "$target")"
      run_aider_node "$scope_dir" "$tag" "${extra_args[@]}"
      ;;
    claudecode)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir claudecode)/run.sh" --variant mcp --image "$(image_name claudecode):$tag" --input-dir "$scope_dir" -- "${extra_args[@]}"
      ;;
    claudecode-solo)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir claudecode)/run.sh" --variant solo --image "$(image_name claudecode-solo):$tag" --input-dir "$scope_dir" -- "${extra_args[@]}"
      ;;
    opencode)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir opencode)/run.sh" --image "$(image_name opencode):$tag" --input-dir "$scope_dir" -- "${extra_args[@]}"
      ;;
    charles-proxy)
      run_charles_proxy "$tag" "${extra_args[@]}"
      ;;
    *)
      print_error "Unsupported run target: $target"
      exit 1
      ;;
  esac
}

debug_target() {
  local target="$1"
  local tag="$2"
  shift 2
  local -a extra_args=("$@")
  local scope_dir

  case "$target" in
    aider-node)
      scope_dir="$(choose_scope "$target")"
      debug_aider_node "$scope_dir" "$tag" "${extra_args[@]}"
      ;;
    claudecode)
      scope_dir="$(choose_scope "$target")"
      PROVEO_CLAUDECODE_IMAGE="$(image_name claudecode):$tag" "$(target_dir claudecode)/mcp/debug.sh" --input-dir "$scope_dir" --output-dir "$(default_claude_output_dir "$scope_dir")" "${extra_args[@]}"
      ;;
    claudecode-solo)
      scope_dir="$(choose_scope "$target")"
      PROVEO_CLAUDECODE_SOLO_IMAGE="$(image_name claudecode-solo):$tag" "$(target_dir claudecode)/solo/debug.sh" --input-dir "$scope_dir" --output-dir "$(default_claude_output_dir "$scope_dir")" "${extra_args[@]}"
      ;;
    charles-proxy)
      debug_charles_proxy "$tag" "${extra_args[@]}"
      ;;
    *)
      print_error "Unsupported debug target: $target"
      exit 1
      ;;
  esac
}

deploy_target() {
  local target="$1"
  local tag="$2"

  local publish_image
  publish_image="$(image_name "$target"):$tag"

  ensure_image_available "$publish_image" "$target"

  print_info "Pushing $publish_image"
  docker push "$publish_image"

  print_success "Deployed $publish_image"
}

run_uninstall() {
  if [[ ! -f "$CONSUMER_UNINSTALL_SCRIPT" ]]; then
    print_error "Consumer uninstall script not found: $CONSUMER_UNINSTALL_SCRIPT"
    exit 1
  fi

  "$CONSUMER_UNINSTALL_SCRIPT"
}

parse_args() {
  local command="${1:-}"
  shift || true

  case "$command" in
    list)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'list' does not accept arguments."
        exit 1
      fi
      list_targets
      ;;
    help)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'help' does not accept arguments."
        exit 1
      fi
      usage
      ;;
    build)
      local target="${1:-}"
      local no_cache=""
      local tag=""
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --no-cache)
            no_cache="--no-cache"
            shift
            ;;
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown build option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "build"
      build_target "$target" "$tag" "$no_cache"
      ;;
    test)
      local target="${1:-}"
      require_target "$target"
      shift || true

      if [[ $# -ne 0 ]]; then
        print_error "Command 'test' does not accept extra arguments."
        exit 1
      fi

      test_target "$target"
      ;;
    run)
      local target="${1:-}"
      local tag=""
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          --)
            shift
            break
            ;;
          *)
            print_error "Unknown run option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "run"
      run_target "$target" "$tag" "$@"
      ;;
    debug)
      local target="${1:-}"
      local tag=""
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          --)
            shift
            break
            ;;
          *)
            print_error "Unknown debug option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "debug"
      debug_target "$target" "$tag" "$@"
      ;;
    deploy)
      local target="${1:-}"
      local tag=""
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown deploy option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "deploy"
      deploy_target "$target" "$tag"
      ;;
    uninstall)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'uninstall' does not accept arguments."
        exit 1
      fi
      run_uninstall
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      print_error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

parse_args "$@"
