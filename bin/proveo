#!/usr/bin/env bash
set -euo pipefail

# Internal maintainer extension of the distributed consumer CLI in apps/cli.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DISTRIBUTABLE_PROVEO="$REPO_ROOT/apps/cli/public/cli/bin/proveo"
CONSUMER_INIT_SCRIPT="$REPO_ROOT/apps/cli/public/cli/bin/init.sh"
CONSUMER_UNINSTALL_SCRIPT="$REPO_ROOT/apps/cli/public/cli/uninstall.sh"
DEFAULT_TAG="latest"

if [[ ! -f "$DISTRIBUTABLE_PROVEO" ]]; then
  echo "❌ Distributable proveo script not found: $DISTRIBUTABLE_PROVEO" >&2
  exit 1
fi

source "$DISTRIBUTABLE_PROVEO"

usage() {
  cat <<'EOF'
Usage:
  bin/proveo list
  bin/proveo help
  bin/proveo init
  bin/proveo build <target> [--tag <tag>] [--no-cache]
  bin/proveo test <target>
  bin/proveo run <target> [--tag <tag>] [-- <args...>]
  bin/proveo debug <target> [--tag <tag>] [-- <args...>]
  bin/proveo deploy <target> [--tag <tag>]
  bin/proveo uninstall

Default tag: latest

Targets:
EOF
  local target
  for target in "${TARGETS[@]}"; do
    echo "  $target"
  done
  cat <<'EOF'

Examples:
  bin/proveo list
  bin/proveo help
  bin/proveo init
  bin/proveo build aider-node --tag latest
  bin/proveo build cecli --tag latest
  bin/proveo build claudecode --tag latest
  bin/proveo build opencode --tag latest
  bin/proveo run aider-node --tag latest
  bin/proveo run cecli-node --tag latest
  bin/proveo run claudecode --tag latest -- --debug --mcp-debug
  bin/proveo debug claudecode-solo --tag latest
  bin/proveo deploy charles-proxy --tag latest
  bin/proveo uninstall
EOF
}

print_success() {
  echo "✅ $*"
}

require_tag() {
  local tag="${1:-}"
  local command_name="${2:-command}"
  if [[ -z "$tag" ]]; then
    print_error "Command '$command_name' received an empty tag."
    exit 1
  fi
}

target_dir() {
  local target="$1"
  case "$target" in
    aider-node)
      echo "$REPO_ROOT/defs/aider-node"
      ;;
    cecli|cecli-node)
      echo "$REPO_ROOT/defs/cecli"
      ;;
    charles-proxy)
      echo "$REPO_ROOT/defs/charles-proxy"
      ;;
    opencode)
      echo "$REPO_ROOT/defs/opencode"
      ;;
    claudecode|claudecode-solo)
      echo "$REPO_ROOT/defs/claudecode"
      ;;
    *)
      print_error "No directory mapping for target: $target"
      exit 1
      ;;
  esac
}

find_script_in_dir() {
  local dir="$1"
  shift
  local script_name
  for script_name in "$@"; do
    if [[ -f "$dir/$script_name" ]]; then
      echo "$dir/$script_name"
      return 0
    fi
  done
  return 1
}

ensure_image_available() {
  local image="$1"
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    print_error "Docker image not found locally: $image"
    print_info "Build it first with: bin/proveo build ${2:-<target>} --tag ${DEFAULT_TAG}"
    exit 1
  fi
}

build_target() {
  local target="$1"
  local tag="$2"
  local no_cache="${3:-}"
  local dir
  dir="$(target_dir "$target")"

  local build_script=""
  build_script="$(find_script_in_dir "$dir" build.sh build.bash 2>/dev/null || true)"

  if [[ -n "$build_script" ]]; then
    print_info "Building $target with tag $tag via $(basename "$build_script")..."
    (
      cd "$dir"
      case "$target" in
        claudecode)
          if [[ -n "$no_cache" ]]; then
            "$build_script" --variant mcp --tag "$tag" --no-cache
          else
            "$build_script" --variant mcp --tag "$tag"
          fi
          ;;
        claudecode-solo)
          if [[ -n "$no_cache" ]]; then
            "$build_script" --variant solo --tag "$tag" --no-cache
          else
            "$build_script" --variant solo --tag "$tag"
          fi
          ;;
        *)
          if [[ -n "$no_cache" ]]; then
            "$build_script" --no-cache
          else
            "$build_script"
          fi
          ;;
      esac
    )

    case "$target" in
      cecli)
        if [[ "$tag" != "$DEFAULT_TAG" ]]; then
          docker tag "$(image_name cecli):latest" "$(image_name cecli):$tag"
        fi
        ensure_image_available "$(image_name cecli):$tag" "$target"
        print_success "Built $(image_name cecli):$tag"
        ;;
      cecli-node)
        if [[ "$tag" != "$DEFAULT_TAG" ]]; then
          docker tag "$(image_name cecli-node):latest" "$(image_name cecli-node):$tag"
        else
          true
        fi
        ensure_image_available "$(image_name cecli-node):$tag" "$target"
        print_success "Built $(image_name cecli-node):$tag"
        ;;
      *)
        if docker image inspect "$(image_name "$target")" >/dev/null 2>&1; then
          docker tag "$(image_name "$target")" "$(image_name "$target"):$tag"
        fi
        ensure_image_available "$(image_name "$target"):$tag" "$target"
        print_success "Built $(image_name "$target"):$tag"
        ;;
    esac
    return 0
  fi

  print_info "Building $target with tag $tag via docker build fallback..."
  docker build ${no_cache:+$no_cache} -t "$(image_name "$target"):$tag" -f "$dir/Dockerfile" "$dir"
  print_success "Built $(image_name "$target"):$tag"
}

test_target() {
  local target="$1"
  local dir
  dir="$(target_dir "$target")"

  local test_script=""
  test_script="$(find_script_in_dir "$dir" test.sh test.bash 2>/dev/null || true)"

  if [[ -n "$test_script" ]]; then
    print_info "Running tests for $target via $(basename "$test_script")..."
    (
      cd "$dir"
      "$test_script"
    )
    print_success "Tests passed for $target"
    return 0
  fi

  case "$target" in
    claudecode|claudecode-solo)
      local claude_tests="$REPO_ROOT/defs/claudecode/tests/run_tests.sh"
      if [[ -f "$claude_tests" ]]; then
        print_info "Running tests for $target via defs/claudecode/tests/run_tests.sh..."
        "$claude_tests"
        print_success "Tests passed for $target"
        return 0
      fi
      ;;
  esac

  print_error "No test script found for $target and no fallback is defined."
  exit 1
}

run_target() {
  local target="$1"
  local tag="$2"
  shift 2
  local -a extra_args=("$@")
  local scope_dir

  case "$target" in
    cecli)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir cecli)/run.sh" --image "$(image_name cecli):$tag" --input-dir "$scope_dir" --repo-root "$REPO_ROOT" -- "${extra_args[@]}"
      ;;
    cecli-node)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir cecli)/run.sh" --image "$(image_name cecli-node):$tag" --input-dir "$scope_dir" --repo-root "$REPO_ROOT" -- "${extra_args[@]}"
      ;;
    claudecode)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir claudecode)/run.sh" --variant mcp --image "$(image_name claudecode):$tag" --input-dir "$scope_dir" -- "${extra_args[@]}"
      ;;
    claudecode-solo)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir claudecode)/run.sh" --variant solo --image "$(image_name claudecode-solo):$tag" --input-dir "$scope_dir" -- "${extra_args[@]}"
      ;;
    opencode)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir opencode)/run.sh" --image "$(image_name opencode):$tag" --input-dir "$scope_dir" -- "${extra_args[@]}"
      ;;
    aider-node)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir aider-node)/run.sh" --image "$(image_name aider-node):$tag" --input-dir "$scope_dir" --repo-root "$REPO_ROOT" -- "${extra_args[@]}"
      ;;
    charles-proxy)
      "$(target_dir charles-proxy)/run.sh" --image "$(image_name charles-proxy):$tag" "${extra_args[@]}"
      ;;
    *)
      print_error "Unsupported run target: $target"
      exit 1
      ;;
  esac
}

debug_target() {
  local target="$1"
  local tag="$2"
  shift 2
  local -a extra_args=("$@")
  local scope_dir

  case "$target" in
    aider-node)
      scope_dir="$(choose_scope "$target")"
      "$(target_dir aider-node)/debug.sh" --image "$(image_name aider-node):$tag" --input-dir "$scope_dir" --repo-root "$REPO_ROOT" -- "${extra_args[@]}"
      ;;
    claudecode)
      scope_dir="$(choose_scope "$target")"
      PROVEO_CLAUDECODE_IMAGE="$(image_name claudecode):$tag" "$(target_dir claudecode)/mcp/debug.sh" --input-dir "$scope_dir" --output-dir "$(default_claude_output_dir "$scope_dir")" "${extra_args[@]}"
      ;;
    claudecode-solo)
      scope_dir="$(choose_scope "$target")"
      PROVEO_CLAUDECODE_SOLO_IMAGE="$(image_name claudecode-solo):$tag" "$(target_dir claudecode)/solo/debug.sh" --input-dir "$scope_dir" --output-dir "$(default_claude_output_dir "$scope_dir")" "${extra_args[@]}"
      ;;
    charles-proxy)
      "$(target_dir charles-proxy)/debug.sh" --image "$(image_name charles-proxy):$tag" "${extra_args[@]}"
      ;;
    *)
      print_error "Unsupported debug target: $target"
      exit 1
      ;;
  esac
}

deploy_target() {
  local target="$1"
  local tag="$2"
  local publish_image
  publish_image="$(image_name "$target"):$tag"

  ensure_image_available "$publish_image" "$target"
  print_info "Pushing $publish_image"
  docker push "$publish_image"
  print_success "Deployed $publish_image"
}

run_uninstall() {
  if [[ ! -f "$CONSUMER_UNINSTALL_SCRIPT" ]]; then
    print_error "Consumer uninstall script not found: $CONSUMER_UNINSTALL_SCRIPT"
    exit 1
  fi

  "$CONSUMER_UNINSTALL_SCRIPT"
}

run_init() {
  if [[ ! -f "$CONSUMER_INIT_SCRIPT" ]]; then
    print_error "Consumer init script not found: $CONSUMER_INIT_SCRIPT"
    exit 1
  fi

  "$CONSUMER_INIT_SCRIPT"
}

parse_args() {
  local command="${1:-}"
  shift || true

  case "$command" in
    list)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'list' does not accept arguments."
        exit 1
      fi
      list_targets
      ;;
    help)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'help' does not accept arguments."
        exit 1
      fi
      usage
      ;;
    init)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'init' does not accept arguments."
        exit 1
      fi
      run_init
      ;;
    build)
      local target="${1:-}"
      local no_cache=""
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --no-cache)
            no_cache="--no-cache"
            shift
            ;;
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown build option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "build"
      build_target "$target" "$tag" "$no_cache"
      ;;
    test)
      local target="${1:-}"
      require_target "$target"
      shift || true

      if [[ $# -ne 0 ]]; then
        print_error "Command 'test' does not accept extra arguments."
        exit 1
      fi

      test_target "$target"
      ;;
    run)
      local target="${1:-}"
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          --)
            shift
            break
            ;;
          *)
            print_error "Unknown run option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "run"
      run_target "$target" "$tag" "$@"
      ;;
    debug)
      local target="${1:-}"
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          --)
            shift
            break
            ;;
          *)
            print_error "Unknown debug option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "debug"
      debug_target "$target" "$tag" "$@"
      ;;
    deploy)
      local target="${1:-}"
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown deploy option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "deploy"
      deploy_target "$target" "$tag"
      ;;
    uninstall)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'uninstall' does not accept arguments."
        exit 1
      fi
      run_uninstall
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      print_error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

parse_args "$@"
