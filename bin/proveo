#!/usr/bin/env bash
set -euo pipefail

# Internal maintainer extension of the distributed consumer CLI in apps/cli.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MAINTAINER_LIB_DIR="$REPO_ROOT/lib"
DISTRIBUTABLE_PROVVE_DIR="$REPO_ROOT/apps/cli/public/cli"
DISTRIBUTABLE_PROVEO="$DISTRIBUTABLE_PROVVE_DIR/bin/proveo"
CONSUMER_INIT_SCRIPT="$DISTRIBUTABLE_PROVVE_DIR/bin/init.sh"
CONSUMER_UNINSTALL_SCRIPT="$DISTRIBUTABLE_PROVVE_DIR/uninstall.sh"
DEFAULT_TAG="latest"

if [[ ! -f "$DISTRIBUTABLE_PROVEO" ]]; then
  echo "❌ Distributable proveo script not found: $DISTRIBUTABLE_PROVEO" >&2
  exit 1
fi

source "$DISTRIBUTABLE_PROVEO"

# Source internal maintainer helper modules
source "$MAINTAINER_LIB_DIR/helpers.sh"
source "$MAINTAINER_LIB_DIR/runners.sh"
source "$MAINTAINER_LIB_DIR/build.sh"
source "$MAINTAINER_LIB_DIR/test.sh"
source "$MAINTAINER_LIB_DIR/deploy.sh"

usage() {
  cat <<'EOF'
Usage:
  bin/proveo list
  bin/proveo help
  bin/proveo init
  bin/proveo build <target> [--tag <tag>] [--no-cache]
  bin/proveo test <target>
  bin/proveo run <target> [--tag <tag>] [-- <args...>]
  bin/proveo debug <target> [--tag <tag>] [-- <args...>]
  bin/proveo deploy <target> [--tag <tag>]
  bin/proveo uninstall

Default tag: latest

Targets:
EOF
  local target
  for target in "${TARGETS[@]}"; do
    echo "  $target"
  done
  cat <<'EOF'

Examples:
  bin/proveo list
  bin/proveo help
  bin/proveo init
  bin/proveo build aider-node --tag latest
  bin/proveo build cecli --tag latest
  bin/proveo build claudecode --tag latest
  bin/proveo build opencode --tag latest
  bin/proveo run aider-node --tag latest
  bin/proveo run cecli-node --tag latest
  bin/proveo run claudecode --tag latest -- --debug --mcp-debug
  bin/proveo debug claudecode-solo --tag latest
  bin/proveo deploy charles-proxy --tag latest
  bin/proveo uninstall
EOF
}

parse_args() {
  local command="${1:-}"
  shift || true

  case "$command" in
    list)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'list' does not accept arguments."
        exit 1
      fi
      list_targets
      ;;
    help)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'help' does not accept arguments."
        exit 1
      fi
      usage
      ;;
    init)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'init' does not accept arguments."
        exit 1
      fi
      run_init
      ;;
    build)
      local target="${1:-}"
      local no_cache=""
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --no-cache)
            no_cache="--no-cache"
            shift
            ;;
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown build option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "build"
      build_target "$target" "$tag" "$no_cache"
      ;;
    test)
      local target="${1:-}"
      require_target "$target"
      shift || true

      if [[ $# -ne 0 ]]; then
        print_error "Command 'test' does not accept extra arguments."
        exit 1
      fi

      test_target "$target"
      ;;
    run)
      local target="${1:-}"
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          --)
            shift
            break
            ;;
          *)
            print_error "Unknown run option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "run"
      run_target "$target" "$tag" "$@"
      ;;
    debug)
      local target="${1:-}"
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          --)
            shift
            break
            ;;
          *)
            print_error "Unknown debug option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "debug"
      debug_target "$target" "$tag" "$@"
      ;;
    deploy)
      local target="${1:-}"
      local tag="$DEFAULT_TAG"
      require_target "$target"
      shift || true

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tag)
            if [[ $# -lt 2 ]]; then
              print_error "--tag requires a value"
              exit 1
            fi
            tag="$2"
            shift 2
            ;;
          *)
            print_error "Unknown deploy option: $1"
            exit 1
            ;;
        esac
      done

      require_tag "$tag" "deploy"
      deploy_target "$target" "$tag"
      ;;
    uninstall)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'uninstall' does not accept arguments."
        exit 1
      fi
      run_uninstall
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      print_error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

parse_args "$@"
