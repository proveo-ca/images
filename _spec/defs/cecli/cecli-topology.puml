@startuml CecliTopology
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho

left to right direction

title Cecli Topology — Pair-Programming Specialist

actor "Human (Pair)" as Human
actor "Cecli (Aider fork)" as Cecli

package "Harness Layer" as Harness {
  component "entrypoint.sh\n(gosu non-root)" as Entrypoint <<script>>
  component ".env + model bridge\n(CECLI_*/AIDER_* vars)" as Env <<logic>>
  component "seed subagents" as Seed <<logic>>
  component "CONVENTIONS.md\n(pair rules)" as ConvMd <<prompt>>
  component ".cecli.conf.yml\n(read CONVENTIONS, agent paths)" as Config <<config>>
}

package "Working Mode" as Mode {
  component "read named files/functions first" as ReadFirst <<rule>>
  component "ask for exact refs on ambiguity" as AskRef <<rule>>
  component "small contained edits only" as SmallEdit <<rule>>
  component "subagents: capped specialists\n(max 3; adversarial, debug, spec)" as SubOpt <<rule>>
}

package "Low-Token Controls" as LowToken {
  component "context-compaction enabled" as Compact <<opt>>
  component "auto-load: false" as NoAuto <<opt>>
  component "Node deps: opt-in only" as NodeOpt <<opt>>
  component "auto-commits: true\n(/undo recovery)" as Commits <<opt>>
}

Human --> Entrypoint : start
Entrypoint --> Env
Entrypoint --> Seed
Entrypoint --> Config
Cecli --> ConvMd : reads pair rules
Cecli --> ReadFirst : human provides file:line
Cecli --> AskRef : when scope unclear
Cecli --> SmallEdit : prefer patch-sized
Human --> Cecli : "read src/foo.ts:42, edit only that fn"
Cecli --> SubOpt : invoke reviewer only if needed

note right of Mode
Pair-programming style:
- Human points to exact code
- Agent does not roam the repo
- Subagents used sparingly
end note

note bottom of LowToken
Designed for precision and
minimal token consumption.
end note

@enduml
