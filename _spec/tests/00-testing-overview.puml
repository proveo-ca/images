@startuml TestingOverview
' SPEC source: defs/tests/run_contract_tests.sh, scripts/go-test-coverage.sh
' The four testing layers: fast + keyless at the base, gated + high-fidelity above.
' Coverage: unit GOCOVERDIR + in-process profiles merge via go tool covdata.
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle

title Testing Approach — Four Layers (speed vs fidelity) + coverage

actor "Developer / CI" as Dev <<actor>>

package "Layer 1 · Unit — always (go test -race)" as L1 {
  component "internal/*/*_test.go\ntable-driven · go-cmp\nno Docker · no keys\n-test.gocoverdir=cov/unit" as Unit <<app>>
}
package "Layer 2 · Contract — always (no Docker)" as L2 {
  component "Go builders + goldens\n(cmd/proveo · runner · provider)\nbash residual: image smoke only" as Contract <<app>>
}
package "Layer 3 · Infra — -tags=integration + PROVEO_EGRESS_INTEGRATION=1" as L3 {
  component "internal/egress BuildPlan\nreal containers · NO model\nwait strategies · t.Cleanup" as Infra <<container>>
}
package "Layer 4 · Agent E2E — -tags=e2e + PROVEO_LLM_TEST=1" as L4 {
  component "internal/tmux + echo-agent\nreal agent · local model\nasserts side-effects" as E2E <<container>>
}
package "Coverage merge" as Cov {
  component "go tool covdata merge\nunit + in-process integration\n(optional: cover-instrumented binary)" as Merge <<app>>
}

Dev --> Unit    : run
Dev --> Contract : run
Dev ..> Infra   : opt-in (Docker + build tag)
Dev ..> E2E     : opt-in (Docker + tmux + Ollama + build tag)
Unit --> Merge
Contract --> Merge
Infra ..> Merge : Stage 0b GOCOVERDIR in proxy image

note right of Unit    : deterministic\nmilliseconds
note right of Contract : deterministic\nseconds
note right of Infra   : deterministic\nDocker + internet, keyless
note right of E2E     : NON-deterministic\nskip if tools/model absent

note bottom of Cov
Default **go test ./...** never compiles Layer 3/4 (build tags).
Coverage v1 merges unit + in-process egressproxy/broker; containerized
proveo-egress cover is Stage 0b (proveo/egress-proxy:cover).
No hard % gate until a baseline exists.
end note

note bottom of L4
Higher layers cost more and are **gated** so the fast, keyless path (L1/L2)
always runs. Only Layer 4 is non-deterministic — it asserts **side effects**,
never model prose.
end note

' --- IGNORE: layout hints (do not edit) ---
L1 -down[hidden]- L2
L2 -down[hidden]- L3
L3 -down[hidden]- L4
L4 -down[hidden]- Cov
' --- END IGNORE ---
@enduml
