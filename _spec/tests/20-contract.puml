@startuml TestingLayer2Contract
' SPEC source: cmd/proveo/main_test.go, internal/runner/runner_test.go
' Layer 2 — Go contract tests on real builders (replacing bash grep). No Docker.
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle

title Layer 2 · Contract — Go builders + goldens (no Docker)

actor "go test ./cmd/... ./internal/...\n(mise test-go)" as Runner <<actor>>

package "Contract suites (Go)" as Suites {
  component "cmd/proveo\nproviderLookup · writeBrokerEnv\nassemble env / sentinel\nCURSOR_API_KEY from host .env" as CLI <<app>>
  component "internal/runner\nDockerRunArgs hardening golden" as RunnerPkg <<app>>
  component "internal/provider\nregistry pins · Detect order" as Provider <<app>>
  component "internal/egress\nBuildPlan goldens (no Docker)" as EgressPlan <<app>>
  component "internal/workspace\n.env mask proxy/firewall\nEnvFileSource" as Workspace <<app>>
  component "shim / Dockerfile\nstructural asserts (Go)" as Struct <<app>>
}

package "Residual bash (optional)" as Bash {
  component "defs/*/tests/test_build.sh\ntest_llm.sh (live keys)" as Residual <<app>>
}

package "Assertion targets" as Targets {
  component "defs/*/run.sh\ndefs/*/harness.manifest" as Defs <<app>>
  component "internal/* (executed, not grepped)" as GoSrc <<app>>
}

Runner --> Suites
Suites --> GoSrc : call / golden
Struct ..> Defs : parse / contain checks
Bash ..> Runner : not on default go test path

note bottom of Suites
**Go-first:** contracts execute builders (DockerRunArgs, BuildPlan, Detect,
writeBrokerEnv) instead of grep-for-substring on source. That catches
regressions bash needles missed (e.g. host .env keys not reaching the broker).
Deterministic; no Docker.
end note

note right of Bash
Image smoke and live LLM stay bash/gated until Stage 3.
run_contract_tests.sh becomes a thin go test wrapper.
end note
@enduml
