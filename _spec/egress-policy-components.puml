@startuml EgressPolicyComponents
' SPEC source: internal/egresspolicy/policy.go, internal/egressproxy/proxy.go
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho

left to right direction

title Egress Policy — read-allow / write-deny / DLP (firewall MITM)

actor "Agent\n(harness container)" as Agent
actor "Operator" as Op

package "Host orchestrator\ncmd/proveo" as Host {
  component "render policy + provider secrets\nfor DLP" as Render <<app>>
  component "mount policy file / env\ninto proveo-egress" as Mount <<app>>
}

package "proveo-egress (firewall only)\nTLS MITM" as Mitm {
  component "brokerModifier\ninject on provider host\nstrip elsewhere" as Broker <<app>>
  component "policyModifier\nDecide after broker" as PolicyMod <<app>>
  package "internal/egresspolicy\n(pure, table-testable)" as Core {
    component "Layer A\nmethod pin\nGET/HEAD/OPTIONS allow\nPOST/PUT/… write-allowlist" as LayerA <<app>>
    component "Layer B\nexfil-sink denylist\nall methods" as LayerB <<app>>
    component "Layer C\nDLP + volume budget\nURL/body secrets, entropy, 8k" as LayerC <<app>>
  }
  component "flows.ndjson\nblocked + allowed records\n(no secret values)" as Flows <<storage>>
}

package "Enforcement hop" as Enforce {
  component "squid:3128\ncleartext + private-range\ndefense-in-depth" as Squid <<container>>
}

package "Destinations" as Dest {
  cloud "Pinned provider\n(inference)" as Provider <<external>>
  cloud "Docs / search\nHTTP(S) reads" as Reads <<external>>
  cloud "Write-allowlisted hosts\ne.g. github.com" as WritesOK <<external>>
  cloud "Exfil sinks\npaste / webhook / tunnel" as Sinks <<external>>
  cloud "Off-allowlist writes\nor secret-bearing requests" as Blocked <<external>>
}

Op ..> Render : --egress-policy / PROVEO_EGRESS_POLICY
Render --> Mount
Mount --> PolicyMod
Agent -[#005F7F,PATH_MAIN]-> Broker : HTTPS via HTTP_PROXY
Broker -[#005F7F,PATH_MAIN]-> PolicyMod : off-provider only
Broker -[#005F7F,bold]-> Provider : inject credential
PolicyMod --> LayerA
PolicyMod --> LayerB
PolicyMod --> LayerC
LayerA ..> LayerB
LayerB ..> LayerC
PolicyMod -[#005F7F,PATH_MAIN]-> Squid : allow → upstream
PolicyMod -[#6E1100,bold]-> Blocked : SkipRoundTrip + 403
PolicyMod --> Flows : decision / reason
Squid --> Reads
Squid --> WritesOK
Squid --> Provider
PolicyMod -[#6E1100,bold]-> Sinks : block (sink)

note bottom of Core
**Off-provider only.** On the pinned-provider host the broker owns
the request and policy is a no-op (injected key never DLP-flagged).
Layers A/B/C require TLS decryption → **firewall mode**.
end note

note right of PolicyMod
Fail closed: block = never contact origin
(""ctx.SkipRoundTrip"") + hijack ""403"".
""CONNECT"" is allowed so the *inner*
request carries method/URL/body.
end note

@enduml
