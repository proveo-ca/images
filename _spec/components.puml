@startuml ProveoComponents
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 100
skinparam ranksep 80

left to right direction

title Proveo Project Component Map

actor "Consumer" as Consumer
actor "Maintainer" as Maintainer
actor "AI Agent" as Agent

package "Repository Root" as RepoRoot {
  component "README / PLAN / CONVENTIONS" as RootDocs <<doc>>
  component "pnpm workspace" as WorkspaceConfig <<config>>
  component "mise toolchain" as ToolchainConfig <<config>>
}

package "Specifications\n_spec/" as Specs {
  component "components.puml" as ComponentsSpec <<spec>>
  component "usage.puml" as UsageSpec <<spec>>
  component "paradigms.md" as Paradigms <<spec>>
  component "claudecode.paradigm.md" as ClaudePara <<spec>>
  component "opencode.paradigm.md" as OpenPara <<spec>>
  component "cecli.paradigm.md" as CecliPara <<spec>>
  component "claudecode-topology.puml" as ClaudeTopo <<spec>>
  component "claudecode-egress-topology.puml" as ClaudeEgressTopo <<spec>>
  component "opencode-topology.puml" as OpenTopo <<spec>>
  component "cecli-topology.puml" as CecliTopo <<spec>>
}

package "Applications\napps/" as Apps {
  package "apps/cli" as AppsCli {
    component "public image assets" as CliAssets <<app>>
    component "proveo\nconsumer CLI\nwith interactive TUI" as ConsumerCli <<app>>
    component "help.sh" as ConsumerHelp <<script>>
    component "uninstall.sh" as ConsumerUninstall <<script>>
    component "wrangler.toml" as WranglerConfig <<config>>
  }
}

package "Maintainer Tools\nmise + lib/" as Bin {
  component "mise tasks\nlib/*.sh helpers" as MaintainerCli <<internal>>
}

package "Definitions\ndefs/" as Defs {
  package "Coding Harness Definitions" as CodingDefs {
    component "cecli\ncandidate" as DefCecli <<definition>>
    component "claudecode\ncandidate; variants: mcp, solo" as DefClaude <<definition>>
    component "opencode\ncandidate" as DefOpen <<definition>>
  }

  package "Egress Layer\ndefs/lib + sidecars/squid-proxy + sidecars/mitmproxy + egress-dashboard" as EgressLayer {
    component "lib/egress.sh\nshared egress lifecycle\nbroker|proxy|firewall" as DefEgressLib <<script>>
    component "squid-proxy\nenforcement proxy + provider allowlist" as DefSquid <<definition>>
    component "mitmproxy\nTLS-inspecting sidecar" as DefMitm <<definition>>
    component "ollama sidecar\noptional local model" as DefOllama <<definition>>
    component "egress-dashboard\nVite + Node timeline + report" as DefDashboard <<app>>
  }
  component "definition-local scripts\nbuild/run/test/debug" as DefinitionScripts <<script>>
  component "Dockerfiles and entrypoints" as DefinitionRuntime <<definition>>
  component "tests/" as DefinitionTests <<test>>
  component "sample configs" as DefinitionConfigs <<config>>
  component "default agent prompts" as DefinitionAgents <<prompt>>
}

package "Shared Packages\npackages/" as Packages {
  component "shared Bash utilities\nfuture extraction" as BashUtils <<package>>
  component "shared CLI libraries\nfuture extraction" as CliLibs <<package>>
  component "subagent definitions\npossible package boundary" as SubagentPackage <<package>>
}

package "Contracts and Docs" as Contracts {
  component "CODING_HARNESSES.md" as HarnessContract <<contract>>
  component "defs/README.md" as DefsContract <<contract>>
  component "per-definition README.md" as DefinitionReadmes <<doc>>
}

package "Artifacts" as Artifacts {
  component "proveo/cecli" as ImgCecli <<image>>
  component "proveo/mitmproxy" as ImgMitm <<image>>
  component "proveo/claudecode" as ImgClaudeMcp <<image>>
  component "proveo/claudecode-solo" as ImgClaudeSolo <<image>>
  component "proveo/opencode" as ImgOpen <<image>>
}

package "Runtime and External Systems" as Runtime {
  component "Docker / containerd" as Containerd <<runtime>>
  component "image registry" as Registry <<external>>
  component "host workspace" as HostWorkspace <<workspace>>
  component "reports / sessions / config dirs" as RuntimeStorage <<storage>>
  component "provider APIs and credentials" as ProviderApis <<external>>
}

Consumer --> ConsumerCli : installed usage
Maintainer --> MaintainerCli : repo-local workflows
Maintainer --> DefinitionScripts : direct deterministic commands
Agent --> RootDocs : collaboration rules
Agent --> Specs : architecture context

ConsumerCli *-- ConsumerHelp
ConsumerCli *-- ConsumerUninstall
CliAssets *-- ConsumerCli
AppsCli *-- WranglerConfig

MaintainerCli ..> DefinitionScripts : delegates or wraps
MaintainerCli ..> ConsumerUninstall : lifecycle helper
MaintainerCli ..> WorkspaceConfig : scope discovery

DefinitionScripts *-- DefinitionRuntime
DefinitionScripts *-- DefinitionTests
DefinitionRuntime *-- DefinitionConfigs
DefinitionRuntime *-- DefinitionAgents

CodingDefs ..> HarnessContract : standard contract
CodingDefs ..> DefsContract : classification
CodingDefs ..> DefinitionReadmes : target-specific usage
DefMitm ..> DefsContract : non-harness allowed

DefClaude ..> DefEgressLib : --egress-mode (broker|proxy|firewall_SLASH)
DefEgressLib ..> DefSquid : starts enforcement + allowlist sidecar
DefEgressLib ..> DefMitm : starts TLS-inspection sidecar
DefEgressLib ..> DefOllama : starts optional local-model sidecar
DefEgressLib ..> DefDashboard : feeds normalized logs + report
DefEgressLib ..> ClaudeEgressTopo : SPEC
DefEgressLib ..> RuntimeStorage : reports/egress/<session>/

DefCecli --> ImgCecli
DefMitm --> ImgMitm
DefClaude --> ImgClaudeMcp
DefClaude --> ImgClaudeSolo
DefOpen --> ImgOpen

ConsumerCli ..> Artifacts : runs published images
DefinitionScripts ..> Artifacts : builds and tests images
MaintainerCli ..> Registry : deploy command pushes images

Artifacts ..> Containerd
ConsumerCli ..> Containerd
DefinitionScripts ..> Containerd
DefinitionScripts ..> HostWorkspace : mounts selected scope
DefinitionScripts ..> RuntimeStorage : writes outputs where applicable
DefinitionRuntime ..> ProviderApis : runtime credentials only

Packages ..> DefinitionScripts : extract only when duplication warrants
Packages ..> ConsumerCli : future shared implementation
SubagentPackage ..> DefinitionAgents : possible source of reusable prompts

Specs ..> RootDocs : document project boundaries
UsageSpec ..> ComponentsSpec : command-level view of components
Paradigms ..> ClaudePara
Paradigms ..> OpenPara
Paradigms ..> CecliPara
ClaudePara ..> ClaudeTopo
ClaudePara ..> ClaudeEgressTopo
OpenPara ..> OpenTopo
CecliPara ..> CecliTopo

note right of ConsumerCli
Consumer CLI lives under apps/cli assets.
It should remain small and consume images,
not own definition-specific behavior.
end note

note right of MaintainerCli
Maintainer workflows run via mise tasks that
source the reusable lib/*.sh helpers.
Definition-local scripts remain the preferred
source of deterministic target behavior.
end note

note bottom of SubagentPackage
Reusable subagents can become a package when
multiple CLIs/images need the same prompt assets.
Until then, defaults may stay with definitions.
end note

note bottom of EgressLayer
Reusable network-egress containment for agent harnesses
(wired into claudecode run today). ""lib/egress.sh"" orchestrates
per-session sidecars and networks: Squid enforces protocol +
provider allowlist, mitmproxy decrypts/records, an optional
Ollama sidecar serves a local model. Squid (""ubuntu/squid"")
and Ollama (""ollama/ollama"") are upstream images; only
""proveo/mitmproxy"" is built here.
end note

@enduml
