@startuml ProveoComponents
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 100
skinparam ranksep 80

left to right direction

title Proveo Project Component Map

actor "Consumer" as Consumer
actor "Maintainer" as Maintainer
actor "AI Agent" as Agent

package "Repository Root" as RepoRoot {
 component "README / plans / CONVENTIONS" as RootDocs <<doc>>
 component "pnpm workspace" as WorkspaceConfig <<config>>
 component "mise toolchain" as ToolchainConfig <<config>>
 component "embed.go\n//go:embed manifests + squid" as Embed <<config>>
}

package "Specifications\n_spec/" as Specs {
 component "components.puml" as ComponentsSpec <<spec>>
 component "usage.puml" as UsageSpec <<spec>>
 component "paradigms.md" as Paradigms <<spec>>
 component "testing.md + tests/*.puml" as TestingSpec <<spec>>
 component "per-harness paradigm + topology" as HarnessSpecs <<spec>>
}

package "Go CLI + packages\ncmd/ + internal/" as GoSurface {
 component "cmd/proveo\nlist · run · projects · setup" as ProveoCLI <<app>>
 component "cmd/proveo-egress\nMITM · broker · detect" as ProveoEgress <<app>>
 component "cmd/proveo-entrypoint\nin-container prelude + sentinel" as ProveoEP <<app>>
 package "internal/" as Internals {
 component "manifest\nharness.manifest" as Manifest <<app>>
 component "runner\nhardened docker argv" as Runner <<app>>
 component "workspace\nscope + mount plan" as Workspace <<app>>
 component "egress\nBuildPlan · lifecycle" as EgressPkg <<app>>
 component "dind\nsibling docker:dind" as DindPkg <<app>>
 component "provider · broker\nregistry + inject/strip" as CredPkg <<app>>
 component "gitidentity\nGIT_* forwarding" as GitId <<app>>
 component "entrypoint\n.env · bridges · sentinel" as EPPkg <<app>>
 }
}

package "Definitions\ndefs/" as Defs {
 package "Coding harnesses" as CodingDefs {
 component "cecli" as DefCecli <<definition>>
 component "claudecode\nmcp + solo" as DefClaude <<definition>>
 component "opencode" as DefOpen <<definition>>
 component "cursor" as DefCursor <<definition>>
 }
 component "harness.manifest\nper def (registration)" as HarnessManifest <<config>>
 component "thin run.sh shims\n→ proveo run" as RunShims <<script>>
 component "build.sh / test.sh\nDockerfiles · entrypoints" as DefBuild <<script>>
 package "Sidecars" as Sidecars {
 component "squid-proxy config" as DefSquid <<definition>>
 component "egress-proxy image\n(proveo-egress)" as DefEgressImg <<definition>>
 component "mitmproxy (legacy)" as DefMitm <<definition>>
 component "dind (public docker:dind)" as DefDind <<definition>>
 }
 component "defaults · agents · samples" as DefAssets <<config>>
}

package "Maintainer tools" as Maint {
 component "mise tasks\nbuild · test · deploy" as Mise <<internal>>
 component "lib/*.sh\nbuild/deploy helpers" as MaintLib <<script>>
}

package "Distribution" as Dist {
 component "goreleaser\nproveo + proveo-egress" as Goreleaser <<config>>
 component "dist/install.sh\nchecksum-verified" as Installer <<script>>
 component "apps/cli (optional CDN)\nrelease assets only" as CliCDN <<app>>
}

package "Artifacts" as Artifacts {
 component "proveo/* harness images" as HarnessImgs <<image>>
 component "proveo/egress-proxy" as EgressImg <<image>>
 component "ubuntu/squid · ollama\n(upstream)" as UpstreamImgs <<image>>
}

package "Runtime" as Runtime {
 component "Docker" as Docker <<runtime>>
 component "host workspace" as HostWS <<workspace>>
 component "state dir\negress · broker secrets" as State <<storage>>
 component "provider APIs" as Providers <<external>>
}

Consumer --> ProveoCLI : installed binary
Consumer --> Installer : curl install + checksum
Maintainer --> Mise : repo workflows
Maintainer --> ProveoCLI : proveo run / --print
Maintainer --> DefBuild : build images
Agent --> RootDocs : collaboration rules
Agent --> Specs : architecture context

ProveoCLI --> Manifest : load targets
ProveoCLI --> Workspace : scope + mounts
ProveoCLI --> Runner : docker run argv
ProveoCLI --> EgressPkg : plan + apply
ProveoCLI --> DindPkg : optional sidecar
ProveoCLI --> GitId : forward identity
ProveoCLI --> CredPkg : detect provider
ProveoCLI --> ProveoEgress : inspector binary
ProveoCLI --> Embed : standalone embeds
ProveoEP --> EPPkg : prep / exec
DefBuild ..> ProveoEP : bake into images

Manifest ..> HarnessManifest : reads / embeds
CodingDefs *-- HarnessManifest
CodingDefs *-- RunShims
CodingDefs *-- DefBuild
CodingDefs *-- DefAssets
RunShims ..> ProveoCLI : exec proveo run

EgressPkg ..> DefSquid : stage config
EgressPkg ..> DefEgressImg : start MITM
EgressPkg ..> UpstreamImgs : squid / ollama
DindPkg ..> DefDind : docker:dind
ProveoEgress ..> CredPkg : inject / strip

Mise ..> MaintLib
Mise ..> DefBuild
Mise ..> ProveoCLI : run / list

Installer ..> Goreleaser : downloads release
CliCDN ..> Goreleaser : hosts assets

DefBuild --> HarnessImgs
DefBuild --> EgressImg
ProveoCLI ..> HarnessImgs : pull / run
ProveoCLI ..> Docker
ProveoCLI ..> HostWS
ProveoCLI ..> State
HarnessImgs ..> Providers : inference (brokered)

Specs ..> RootDocs
UsageSpec ..> ComponentsSpec
Paradigms ..> HarnessSpecs
TestingSpec ..> Internals

note right of ProveoCLI
**Single host orchestrator.**
Hardened docker argv, egress topology,
DinD, mounts, and env wizard live here.
Consumer install is the static binary only
— not a curl|bash of live shell libs.
end note

note right of RunShims
defs/*/run.sh are thin shims to
""proveo run <target>"". Fat bash
runners and lib/egress.sh orchestration
are retired (Round 2).
end note

note bottom of EgressPkg
firewall (default): agent → proveo-egress
(MITM + credential broker) → Squid → net.
proxy: Squid only. broker: container boundary.
Policy + flow log at the MITM hop.
end note

@enduml
