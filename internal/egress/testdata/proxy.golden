# networks
docker network create --label proveo.egress.session=proveo-sess --internal proveo-sess-claudecode-mcp-squid-net
docker network create --label proveo.egress.session=proveo-sess proveo-sess-squid-egress-net
# sidecars
docker run -d --rm --name proveo-sess-squid --label proveo.egress.session=proveo-sess --security-opt=no-new-privileges:true --pids-limit=256 --network proveo-sess-squid-egress-net -v /state/squid/config:/etc/squid:ro -v /state/squid/logs:/var/log/squid ubuntu/squid:latest
# connects
docker network connect --alias squid proveo-sess-claudecode-mcp-squid-net proveo-sess-squid
# agent-args
--network proveo-sess-claudecode-mcp-squid-net --dns 0.0.0.0 -e ENFORCEMENT_PROXY=http://squid:3128 -e PROVEO_EGRESS_SESSION_ID=proveo-sess -e PROVEO_EGRESS_MODE=proxy -e HTTP_PROXY=http://squid:3128 -e HTTPS_PROXY=http://squid:3128 -e http_proxy=http://squid:3128 -e https_proxy=http://squid:3128
# cleanup
docker rm -f proveo-sess-squid
docker network rm proveo-sess-claudecode-mcp-squid-net
docker network rm proveo-sess-squid-egress-net
