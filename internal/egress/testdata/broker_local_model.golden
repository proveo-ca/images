# networks
docker network create --label proveo.egress.session=proveo-sess proveo-sess-claudecode-mcp-broker-net
# sidecars
docker run -d --rm --name proveo-sess-ollama --label proveo.egress.session=proveo-sess --cap-drop=ALL --security-opt=no-new-privileges:true --pids-limit=256 --network proveo-sess-claudecode-mcp-broker-net --network-alias ollama -e OLLAMA_HOST=0.0.0.0:11434 -e OLLAMA_MODELS=/models -e OLLAMA_CONTEXT_LENGTH=32768 -v /home/tester/.ollama/models:/models:ro ollama/ollama:latest
# connects
# agent-args
--network proveo-sess-claudecode-mcp-broker-net -e PROVEO_LOCAL_MODEL=gemma4 -e OLLAMA_HOST=http://ollama:11434 -e OLLAMA_API_BASE=http://ollama:11434 -e OPENAI_BASE_URL=http://ollama:11434/v1 -e OPENAI_API_KEY=ollama -e ARCHITECT_MODEL=ollama/gemma4 -e EDITOR_MODEL=ollama/gemma4 -e SMALL_MODEL=ollama/gemma4 -e ANTHROPIC_BASE_URL=http://ollama:11434 -e ANTHROPIC_AUTH_TOKEN=ollama -e ANTHROPIC_API_KEY= -e ANTHROPIC_MODEL=gemma4 -e ANTHROPIC_SMALL_FAST_MODEL=gemma4 -e NO_PROXY=ollama,host.docker.internal,localhost,127.0.0.1 -e no_proxy=ollama,host.docker.internal,localhost,127.0.0.1
# ollama-wait
proveo-sess-ollama
# cleanup
docker rm -f proveo-sess-ollama
docker network rm proveo-sess-claudecode-mcp-broker-net
