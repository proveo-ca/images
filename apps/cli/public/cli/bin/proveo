#!/usr/bin/env bash
set -euo pipefail

PROVEO_VERSION="0.0.1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROVEO_LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"

TARGETS=(
  "aider-node"
  "cecli"
  "cecli-node"
  "charles-proxy"
  "opencode"
  "claudecode"
  "claudecode-solo"
)

# Source helper modules
source "$PROVEO_LIB_DIR/ui.sh"
source "$PROVEO_LIB_DIR/workspace.sh"
source "$PROVEO_LIB_DIR/runners.sh"

usage() {
  cat <<'EOF'
Usage:
  proveo help
  proveo init
  proveo list
  proveo run <target> [-- <args...>]
  proveo uninstall
  proveo version

Targets:
  aider-node
  cecli
  cecli-node
  charles-proxy
  claudecode
  claudecode-solo
  opencode

Examples:
  proveo help
  proveo init
  proveo list
  proveo run aider-node
  proveo run cecli-node
  proveo run claudecode -- --debug --mcp-debug
  proveo run opencode
  proveo uninstall
EOF
}

print_error() {
  echo "❌ $*" >&2
}

print_info() {
  echo "ℹ️  $*"
}

if [[ -t 0 && -t 1 && -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  CYAN=$'\033[36m'
  BLUE=$'\033[34m'
  GREEN=$'\033[32m'
  YELLOW=$'\033[33m'
  RESET=$'\033[0m'
else
  BOLD=""
  DIM=""
  CYAN=""
  BLUE=""
  GREEN=""
  YELLOW=""
  RESET=""
fi

is_tty() {
  [[ -n "${PROVEO_FORCE_TTY:-}" ]] || [[ -t 0 ]]
}

is_valid_target() {
  local target="$1"
  local item
  for item in "${TARGETS[@]}"; do
    if [[ "$item" == "$target" ]]; then
      return 0
    fi
  done
  return 1
}

require_target() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    print_error "Missing target."
    usage
    exit 1
  fi

  if ! is_valid_target "$target"; then
    print_error "Unknown target: $target"
    echo ""
    usage
    exit 1
  fi
}

list_targets() {
  echo "Available targets:"
  local target
  for target in "${TARGETS[@]}"; do
    echo "  - $target"
  done
}

is_ai_harness() {
  local target="$1"
  case "$target" in
    aider-node|cecli|cecli-node|claudecode|claudecode-solo|opencode)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

CURRENT_REPO_ROOT="$(find_repo_root)"

show_help_command() {
  "$SCRIPT_DIR/help.sh"
}

run_init() {
  "$SCRIPT_DIR/init.sh"
}

run_uninstall() {
  PROVEO_INSTALL_ROOT="$INSTALL_ROOT" "$INSTALL_ROOT/uninstall.sh"
}

parse_args() {
  local command="${1:-}"
  shift || true

  case "$command" in
    list)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'list' does not accept arguments."
        exit 1
      fi
      list_targets
      ;;
    help)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'help' does not accept arguments."
        exit 1
      fi
      show_help_command
      ;;
    init)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'init' does not accept arguments."
        exit 1
      fi
      run_init
      ;;
    run)
      local target="${1:-}"
      if [[ -z "$target" ]]; then
        run_interactive_target_menu
        return 0
      fi
      require_target "$target"
      shift || true

      if [[ "${1:-}" == "--" ]]; then
        shift
      fi

      run_target "$target" "$@"
      ;;
    uninstall)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'uninstall' does not accept arguments."
        exit 1
      fi
      run_uninstall
      ;;
    version|-v|--version)
      if [[ $# -ne 0 ]]; then
        print_error "Command 'version' does not accept arguments."
        exit 1
      fi
      echo "proveo version $PROVEO_VERSION"
      ;;
    -h|--help|"")
      if [[ -z "$command" ]] && is_tty; then
        run_interactive_main_menu
      else
        usage
      fi
      ;;
    *)
      print_error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  parse_args "$@"
fi
