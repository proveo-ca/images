# SPEC: _spec/components.puml
# Single registration point for the claudecode harness (Plan 2). Adding or
# changing a harness should touch only this file + the def dir it lives in.
name: claudecode
description: ML-loop harness (Claude Code, --dangerously-skip-permissions)
egress: true
stability: candidate
images:
  claudecode: proveo/claudecode:latest
  claudecode-browser: proveo/claudecode-browser:latest
  claudecode-solo: proveo/claudecode-solo:latest
  # mcp + Solidity/security toolchain (Foundry, solc, solhint, semgrep)
  claudecode-sol: proveo/claudecode-sol:latest
workspace:
  layout: input-output
env:
  - name: CLAUDE_CODE_OAUTH_TOKEN
    description: Claude Code OAuth token — generate one with `claude setup-token`
    secret: true
