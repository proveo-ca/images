# SPEC: _spec/components.puml
name: cursor
description: Policy-gated autonomous loop (Cursor CLI, --force + native deny rules)
egress: true
dind: true
stability: candidate
images:
  cursor: proveo/cursor:latest
workspace:
  layout: app
  configDir: .cursor
  gitMode: rw
env:
  - name: CURSOR_API_KEY
    description: Cursor API key — create one at cursor.com/dashboard → API Keys
    secret: true
