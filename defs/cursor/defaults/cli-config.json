{
  "version": 1,
  "permissions": {
    "allow": [],
    "deny": [
      "Shell(sudo)",
      "Shell(su)",
      "Shell(shutdown)",
      "Shell(reboot)",
      "Shell(poweroff)",
      "Shell(nc)",
      "Shell(netcat)",
      "Shell(ncat)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/.ssh/**)",
      "Write(**/.ssh/**)",
      "Read(**/.aws/credentials)"
    ]
  }
}
