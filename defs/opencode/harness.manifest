# SPEC: _spec/components.puml
name: opencode
description: Subagent-crew workflow (OpenCode, HITL oversight)
egress: true
dind: true
stability: candidate
images:
  opencode: proveo/opencode:latest
  opencode-browser: proveo/opencode-browser:latest
workspace:
  layout: app
  configDir: .opencode
  gitMode: rw
home:
  enabled: true
  mounts:
    - host: opencode/config
      container: /proveo-home/.config/opencode
      mode: rw
    - host: opencode/share
      container: /proveo-home/.local/share/opencode
      mode: rw
      deny: [auth.json]
